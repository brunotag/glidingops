# .htaccess
DirectoryIndex home.php
RewriteEngine On

# if maintenance.trigger exists, then reply with
# 503 Temporarily Unavailable
RewriteCond %{ENV:REDIRECT_STATUS} !=503
RewriteCond "/var/www/html/maintenance.trigger" -f
RewriteRule ^(.*)$ /$1 [R=503,L]

RewriteRule   ^app/css/(.*)    /lrv/public/css/$1  [L]
RewriteRule   ^app/(.*)    /lrv/public/app/$1  [L]

# this is the in-house manually built api
RewriteRule api/v1/json/(.*)$ apiglidjsonv1.php?r=$1 [QSA,NC,L]

# this is the laravel api
RewriteRule   ^api/v2/(.*)    /lrv/public/api/v2/$1  [L]

# DataTables API for flights report
RewriteRule ^api/flights-report$ api/flights-report.php [L,QSA]

# Analytics data API
RewriteRule ^api/analytics-data$ api/analytics-data.php [L,QSA]

# Member autocomplete search API
RewriteRule ^api/member-search$ api/member-search.php [L,QSA]

# DataTables API for members
RewriteRule ^api/members$ api/members.php [L,QSA]

# Members email autocomplete API
RewriteRule ^api/members-email$ api/members-email.php [L,QSA]

# DataTables API for users
RewriteRule ^api/users$ api/users.php [L,QSA]

# User form API (create/update)
RewriteRule ^api/user-form$ api/user-form.php [L,QSA]

# MyFlights data API
RewriteRule ^api/myflights$ api/myflights-data.php [L,QSA]

# Daily flights API
RewriteRule ^api/daily-flights$ api/daily-flights.php [L,QSA]

# Magic link login API
RewriteRule ^api/magic-link-request$ api/magic-link-request.php [L,QSA]
RewriteRule ^api/magic-link-verify$ api/magic-link-verify.php [L,QSA]

# JS debug API
RewriteRule ^api/js-debug$ api/js-debug.php [L,QSA]

# Texts/Messages API
RewriteRule ^api/texts$ api/texts.php [L,QSA]
RewriteRule texts-list texts-list-v2b.php [L,QSA]
RewriteRule texts-list-old texts-list.php [L,QSA]
RewriteRule SentMessages texts-list-v2b.php [L,QSA]
RewriteRule MessagesTree messages-tree.php [L,QSA]

# New members list (v2b is now the default)
RewriteRule AllMembers members-list-v2b.php [L,QSA]
RewriteRule MembersListOld members-list.php [L]

# New member create/edit page
RewriteRule MemberNew members-new.php [L,QSA]
RewriteRule EditMyDetails members-new.php [L,QSA]

# Invite Users (must come BEFORE Users rules to avoid collision)
RewriteRule InviteUsers invite-users.php [L,QSA]

# New users list and create/edit
RewriteRule UsersList users-list-v2b.php [L,QSA]
RewriteRule Users/([0-9]+) users-new.php?id=$1 [L,QSA]
RewriteRule Users users-new.php [L,QSA]

RewriteRule home home.php [L]
RewriteRule ViewAs ViewAs.php [L,QSA]
RewriteRule AssignRoles role_member-list.php [L]
RewriteRule AssignRole role_member.php [L]
RewriteRule FlightTypes flighttypes-list.php [L]
RewriteRule FlightType flighttypes.php [L]
RewriteRule FlyingNow FlyingNow.php [L]
RewriteRule MessagingPageOld MessagingPageOld.php [L,QSA]
RewriteRule MessagingPage MessagingPage.php [L,QSA]
RewriteRule AircraftTypes aircrafttype-list.php [L]
RewriteRule AircraftType aircrafttype.php [L]
RewriteRule AllAircraft aircraft-list.php [L]
RewriteRule Aircraft aircraft.php [L]
RewriteRule AllMembers members-list.php [L]
RewriteRule AllFlightsMobile AllFlightsReportMobile.php [L,QSA]
RewriteRule AllFlightsReportNew AllFlightsReportNew.php [L,QSA]
RewriteRule Analytics analytics-dashboard.php [L,QSA]
RewriteRule BillingOptions billingoptions-list.php [L]
RewriteRule BillingOption billingoptions.php [L]

RewriteRule EditDailySheet EditDailySheet.php [L,QSA]
RewriteRule DailyLogSheet DailyLogSheet.php [L,QSA]
RewriteRule StartDay StartDay.php [L,QSA]
RewriteRule last-flights-list last-flights-list.php [L,QSA]
RewriteCond %{REQUEST_FILENAME} !\.(jpg|gif|js|css)$
RewriteRule ^DailySheet$ dailysheet.php [L]

RewriteRule DutyTypes dutytypes-list.php [L]
RewriteRule DutyType dutytypes.php [L]
RewriteRule IncentiveSchemes incentive_schemes-list.php [L]
RewriteRule IncentiveScheme incentive_schemes.php [L]
RewriteRule LaunchTypes launchtypes-list.php [L]
RewriteRule LaunchType launchtypes.php [L]
RewriteRule Organisations organisations-list.php [L]
RewriteRule Organisation organisations.php [L]
RewriteRule Member members.php [L]
RewriteRule Aircraft aircraft.php [L]

RewriteRule Roles roles-list.php [L]
RewriteRule Role roles.php [L]
RewriteRule Rosters duty-list.php [L]
RewriteRule Roster duty.php [L]
RewriteRule SubsToSchemes scheme_subs-list.php [L]
RewriteRule SubsToScheme scheme_subs.php [L]
RewriteRule OtherCharges charges-list.php [L]
RewriteRule OtherCharge charges.php [L]
RewriteRule TowCharges towcharges-list.php [L]
RewriteRule TowCharge towcharges.php [L]
RewriteRule MyFlightsCSV MyFlightsCSV.php [L]
RewriteRule MyFlights MyFlights.php [L]
RewriteRule TreasurerReportNew4 TreasurerReportNew4.php [L,QSA]
RewriteRule TreasurerReportNew4.csv TreasurerReportNew4.php [L,QSA]
RewriteRule TreasurerReportNew3 TreasurerReportNew3.php [L,QSA]
RewriteRule TreasurerReportNew3.csv TreasurerReportNew3.php [L,QSA]
RewriteRule GlideAccounts.csv Treasurer2.php [L,QSA]
RewriteRule Engineering.csv Engineer2.php [L]
RewriteRule Engineer Engineer.php [L,QSA]
RewriteRule OlcFile.igc igcgenerate.php [L]
RewriteRule PasswordChange PasswordChange.php [L]
RewriteRule agc MasterDisplay.php?org=4 [L,QSA]
RewriteRule cgc MasterDisplay.php?org=3 [L,QSA]
RewriteRule ssb MasterDisplay.php?org=2 [L,QSA]
RewriteRule ^Bookings$ bookings.php [L,QSA]
RewriteRule wgc-new MasterDisplayNew.php?org=1 [L,QSA]
RewriteRule wgc MasterDisplay.php?org=1 [L,QSA]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# disable directory browsing, specifically .git
RedirectMatch 404 /\.git
Options -Indexes