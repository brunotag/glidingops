{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "laravelcollective/html": "^6.0",
        "laravel/framework": "^8.0",
        "laravel/tinker": "^2.0",
        "laravel/ui": "^3.0",
        "noweh/twitter-api-v2-php": "^3.1",
        "google/apiclient": "^1.1",
        "phpmailer/phpmailer": "^7.1"
    },
    "require-dev": {
        "mockery/mockery": "^0.9",
        "phpunit/phpunit": "^9.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/css-selector": "^3.1",
        "symfony/dom-crawler": "^3.1",
        "kitloong/laravel-migrations-generator": "^6.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpcompatibility/php-compatibility": "^9.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.2",
        "fakerphp/faker": "^1.20"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/TestCase.php"
        ]
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall",
            "php artisan optimize"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "php artisan optimize"
        ],
        "phpcs" : [
            "phpcs -i",
            "mkdir -p ./phpcs/reports",
            "phpcs -p ../ --ignore=*/vendor/* --extensions=php --report=xml --report-file=./phpcs/report.xml || true",
            "xsltproc ./phpcs/phpcshtml.xsl ./phpcs/report.xml > ./phpcs/reports/report-$(date +\"%FT%H%M\").html",
            "rm ./phpcs/report.xml"
        ],
        "phpcbf" : [
            "phpcbf -p ../ --ignore=*/vendor/* --extensions=php"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "allow-plugins": {
            "kylekatarnls/update-helper": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "audit": {
            "ignore": ["PKSA-8qx3-n5y5-vvnd", "PKSA-w7xr-vk7n-rstm", "PKSA-p3rx-dfwp-73ny", "PKSA-ckwp-rt7t-c46m", "PKSA-4npr-btr6-zhny", "PKSA-njrm-6dtg-m2pc", "PKSA-985r-hryy-555b"]
        },
        "platform": {
            "php": "7.4"
        }
    }
}
