{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "docs/DEVELOP.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/DEAD_CODE.md", "docs/DATABASE.md", "docs/ROUTES.md", "docs/CODEBASE_MAP.md"],
  "snapshot": true,
  "autoupdate": true,
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "delete": "ask"
  },
  "lsp": {
    "php": {
      "disabled": true
    }
  },
  "watcher": {
    "ignore": ["log/*", "var/*", "vendor/*", "node_modules/*", ".git/*", ".opencode/.domshell_token"]
  },
  "mcp": {
    "agentmemory": {
      "type": "local",
      "command": ["npx", "-y", "@agentmemory/mcp", "--tools", "all", "--force-proxy"],
      "enabled": true
    },
    "domshell": {
      "type": "remote",
      "url": "http://localhost:3001/mcp?token={env:DOMSHELL_TOKEN}",
      "oauth": false,
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}